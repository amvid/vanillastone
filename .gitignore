# Binaries
/vanillastone
*.exe
/cmd/server/server
bin/
tmp/

# SQLite (player decks — runtime data)
*.db
*.sqlite
*.sqlite3

# Web (Vite client, when scaffolded)
web/node_modules/
web/dist/
web/.vite/
# Vite build output: reproducible from web/public + sources (prod Dockerfile
# rebuilds it). Tracking it duplicated public/art into static/art. Keep only
# the .gitkeep placeholder so //go:embed static still compiles.
web/static/*
!web/static/.gitkeep

# Env / secrets
.env
.env.local

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
.zed/

# Go
*.test
*.out

# Private notes (reference card mapping — real names never in the public repo)
.notes/
